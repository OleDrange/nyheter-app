---
import '../styles/global.css';
import ThemePicker from '../components/ThemePicker.astro';

// Fanetittel: «modr - <site> - <dato/seksjon>». Sidene sender bare datodelen.
// `site="forskning"` gir forskningssidens header/nav; `base` er lenkeprefikset
// for interne forskning-lenker ('' på forskning.modr.no, '/forskning' ellers).
const { title, site = 'nyheter', base = '' } = Astro.props;
const isForskning = site === 'forskning';
const fullTitle = title ? `modr - ${site} - ${title}` : `modr - ${site}`;
const path = Astro.url.pathname;
const isHome = isForskning
  ? path === '/forskning' || path === '/forskning/'
  : path === '/';
const isArchive = isForskning ? path.startsWith('/forskning/arkiv') : path.startsWith('/arkiv');
---

<!doctype html>
<html lang="no">
  <head>
    <meta charset="utf-8" />
    {/* Sett tema før paint (unngår blink): lagret valg, ellers systemets preferanse. */}
    <script is:inline>
      (() => {
        try {
          let t = localStorage.getItem('theme');
          if (!t) t = matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
          document.documentElement.setAttribute('data-theme', t);
        } catch (e) {}
      })();
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{fullTitle}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="site-header__inner">
        <div class="brand">
          <a href={isForskning ? base || '/' : '/'}>
            <span class="brand__mark">{isForskning ? '🔬 Forskning' : '📰 Nyhetsbriefing'}</span>
          </a>
          <span class="brand__sub">{isForskning ? 'medisin · trening · kosthold' : 'Bergen · daglig'}</span>
        </div>
        <div class="header-actions">
          <nav class="nav">
            {isForskning ? (
              <>
                <a href={base || '/'} aria-current={isHome ? 'page' : undefined}>I dag</a>
                <a href={`${base}/arkiv`} aria-current={isArchive ? 'page' : undefined}>Arkiv</a>
                <a href="https://nyheter.modr.no">Nyheter</a>
              </>
            ) : (
              <>
                <a href="/" aria-current={isHome ? 'page' : undefined}>I dag</a>
                <a href="/arkiv" aria-current={isArchive ? 'page' : undefined}>Arkiv</a>
                <a href="https://forskning.modr.no">Forskning</a>
              </>
            )}
          </nav>
          <ThemePicker />
        </div>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      Daglig nyhets- og forskningsbriefing · oppsummert med Claude
    </footer>
  </body>
</html>
