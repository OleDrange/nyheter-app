---
import '../styles/global.css';
import ThemePicker from '../components/ThemePicker.astro';

// Fanetittel: «modr - <site> - <dato/seksjon>». Sidene sender bare datodelen.
// `site="forskning"` gir forskningssidens header/nav; `base` er lenkeprefikset
// for interne forskning-lenker ('' på forskning.modr.no, '/forskning' ellers).
const { title, site = 'nyheter', base = '' } = Astro.props;
const isForskning = site === 'forskning';
const fullTitle = title ? `modr - ${site} - ${title}` : `modr - ${site}`;
const path = Astro.url.pathname;
const isHome = isForskning
  ? path === '/forskning' || path === '/forskning/'
  : path === '/';
const isArchive = isForskning ? path.startsWith('/forskning/arkiv') : path.startsWith('/arkiv');

// Dagens dato i headeren — beregnes per forespørsel (SSR) i container-TZ (Europe/Oslo).
const _today = new Intl.DateTimeFormat('nb-NO', {
  weekday: 'long',
  day: 'numeric',
  month: 'long',
}).format(new Date());
const todayNo = _today.charAt(0).toUpperCase() + _today.slice(1);
---

<!doctype html>
<html lang="no">
  <head>
    <meta charset="utf-8" />
    {/* Sett tema før paint (unngår blink): lagret valg, ellers systemets preferanse. */}
    <script is:inline>
      (() => {
        try {
          let t = localStorage.getItem('theme');
          if (!t) t = matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
          document.documentElement.setAttribute('data-theme', t);
        } catch (e) {}
      })();
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{fullTitle}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="site-header__inner">
        <div class="brand">
          <a href={isForskning ? base || '/' : '/'}>
            <span class="brand__mark">{isForskning ? '🔬 Forskning' : '📰 Nyhetsbriefing'}</span>
          </a>
          <span class="brand__sub">{isForskning ? 'medisin · trening · kosthold' : 'Bergen · daglig'}</span>
          <span class="brand__date">{todayNo}</span>
        </div>
        <div class="header-actions">
          <nav class="nav">
            {isForskning ? (
              <>
                <a href={base || '/'} aria-current={isHome ? 'page' : undefined}>I dag</a>
                <a href={`${base}/arkiv`} aria-current={isArchive ? 'page' : undefined}>Arkiv</a>
                <a href="https://nyheter.modr.no">Nyheter</a>
              </>
            ) : (
              <>
                <a href="/" aria-current={isHome ? 'page' : undefined}>I dag</a>
                <a href="/arkiv" aria-current={isArchive ? 'page' : undefined}>Arkiv</a>
                <a href="https://forskning.modr.no">Forskning</a>
              </>
            )}
          </nav>
          <ThemePicker />
        </div>
      </div>
      {!isForskning && (
        <nav class="jumpnav" aria-label="Hopp til seksjon" hidden>
          <div class="jumpnav__inner">
            <a href="#vaer-marked">Vær og marked</a>
            <a href="#gaater">Gåter</a>
            <a href="#quiz">Quiz</a>
            <a href="#inspirasjon">Inspirasjon</a>
            <a href="#nyheter">Nyheter</a>
          </div>
        </nav>
      )}
    </header>

    {/* Hopp-raden: vis kun lenker med eksisterende mål (arkivsiden har ingen),
        og scroll dit med kort animasjon (~0,5 s) i stedet for hardt hopp. */}
    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
        const nav = document.querySelector('.jumpnav');
        if (!nav) return;
        let any = false;
        nav.querySelectorAll('a').forEach((a) => {
          const el = document.getElementById(a.getAttribute('href').slice(1));
          if (!el) { a.remove(); return; }
          any = true;
          a.addEventListener('click', (e) => {
            e.preventDefault();
            const headerH = document.querySelector('.site-header')?.offsetHeight ?? 0;
            const targetY = el.getBoundingClientRect().top + window.scrollY - headerH - 10;
            if (matchMedia('(prefers-reduced-motion: reduce)').matches) {
              window.scrollTo(0, targetY);
              return;
            }
            const startY = window.scrollY;
            const dist = targetY - startY;
            const dur = 500;
            const t0 = performance.now();
            const ease = (t) => (t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2);
            const step = (now) => {
              const t = Math.min((now - t0) / dur, 1);
              window.scrollTo(0, startY + dist * ease(t));
              if (t < 1) requestAnimationFrame(step);
            };
            requestAnimationFrame(step);
          });
        });
        if (any) nav.hidden = false;
      });
    </script>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      Daglig nyhets- og forskningsbriefing · oppsummert med Claude
    </footer>
  </body>
</html>
