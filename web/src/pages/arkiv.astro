---
import Base from '../layouts/Base.astro';
import { listDates, formatDateNo, weekdayNo } from '../lib/briefings.js';

const dates = await listDates();
---

<Base title="arkiv">
  <div class="page-head">
    <h1>Arkiv</h1>
    <div class="date">{dates.length} briefinger</div>
  </div>
  {
    dates.length ? (
      <div class="archive-grid">
        {dates.map((d) => (
          <a class="card archive-card" href={`/b/${d}`}>
            {formatDateNo(d, { day: 'numeric', month: 'short', year: 'numeric' })}
            <span class="weekday">{weekdayNo(d)}</span>
          </a>
        ))}
      </div>
    ) : (
      <p class="empty">Ingen briefinger ennå.</p>
    )
  }
</Base>
