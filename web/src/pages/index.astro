---
import Base from '../layouts/Base.astro';
import BriefingView from '../components/BriefingView.astro';
import { listDates, getBriefing, formatDateNo } from '../lib/briefings.js';

const dates = await listDates();
const b = dates.length ? await getBriefing(dates[0]) : null;
---

<Base title={b ? `Briefing ${b.date}` : 'Nyhetsbriefing'}>
  {
    b ? (
      <>
        <div class="page-head">
          <h1>Dagens briefing</h1>
          <div class="date">{formatDateNo(b.date)}</div>
        </div>
        <BriefingView b={b} />
      </>
    ) : (
      <p class="empty">Ingen briefing generert ennå.</p>
    )
  }
</Base>
