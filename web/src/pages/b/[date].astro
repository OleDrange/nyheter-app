---
import Base from '../../layouts/Base.astro';
import BriefingView from '../../components/BriefingView.astro';
import { getBriefing, formatDateNo } from '../../lib/briefings.js';

const { date } = Astro.params;
const b = await getBriefing(date);

if (!b) {
  return new Response('Ikke funnet', { status: 404 });
}
---

<Base title={b.date}>
  <p class="back"><a href="/arkiv">← Tilbake til arkiv</a></p>
  <div class="page-head">
    <h1>Briefing</h1>
    <div class="date">{formatDateNo(b.date)}</div>
  </div>
  <BriefingView b={b} />
</Base>
