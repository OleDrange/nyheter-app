---
// Markeds-widget. Bygger på det strukturerte `market`-objektet
// (fetch_market_snapshot): brent, sp500, osebx (m/ *_chg), eurnok, usdnok.
const { market } = Astro.props;
const m = market || {};

const fmt = (n, d = 2) =>
  n == null ? '–' : n.toLocaleString('nb-NO', { minimumFractionDigits: d, maximumFractionDigits: d });

const ticks = [
  { name: 'Brent', value: m.brent, chg: m.brent_chg, d: 1, unit: ' $' },
  { name: 'S&P 500', value: m.sp500, chg: m.sp500_chg, d: 0 },
  { name: 'OBX', value: m.osebx, chg: m.osebx_chg, d: 1 },
  { name: 'EUR/NOK', value: m.eurnok, chg: null, d: 2 },
  { name: 'USD/NOK', value: m.usdnok, chg: null, d: 2 },
];

const hasData = !m.error && ticks.some((t) => t.value != null);
---

<div class="card market">
  <div class="market__head">Marked</div>
  {
    hasData ? (
      <div class="market__grid">
        {ticks.map((t) => (
          <div class="tick">
            <div class="tick__name">{t.name}</div>
            <div>
              <span class="tick__value">
                {fmt(t.value, t.d)}
                {t.value != null && t.unit ? t.unit : ''}
              </span>
              {t.chg != null && (
                <span class={t.chg >= 0 ? 'tick__chg chg-up' : 'tick__chg chg-down'}>
                  {t.chg >= 0 ? '▲' : '▼'} {Math.abs(t.chg).toFixed(2)}%
                </span>
              )}
            </div>
          </div>
        ))}
      </div>
    ) : (
      <p class="muted">Markedsdata utilgjengelig.</p>
    )
  }
</div>
