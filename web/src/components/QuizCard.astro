---
// Dagens hjernetrim — ett flervalgsspørsmål per kategori fra det lokale
// spørsmålsbiblioteket (quiz_bank/), nivå merket lett/middels/vanskelig.
// Antall spørsmål følger antall kategorier, så komponenten er antalluavhengig.
// Fasit er skjult til brukeren trykker på et svaralternativ; riktig svar
// markeres grønt, feil valg rødt. Ingen bundling — ren inline-script.
import SaveButton from './SaveButton.astro';
import { buildId } from '../lib/saved.js';
const { quiz, date = '', canPin = false, saved = new Set() } = Astro.props;

const DIFF_NO = { easy: 'Lett', medium: 'Middels', hard: 'Vanskelig' };
---

<div class="cards-grid quiz-grid">
  {quiz.map((q, i) => (
    <article class={`card quiz-q${q.repeat ? ' quiz-q--repeat' : ''}`} data-answer={q.answer}>
      <header class="quiz-q__head">
        <span class="quiz-q__badges">
          <span class={`quiz-q__level quiz-q__level--${q.difficulty}`}>
            Nivå {q.level ?? i + 1} · {DIFF_NO[q.difficulty] ?? q.difficulty}
          </span>
          {q.repeat && (
            <span class="quiz-q__repeat" title="Du har sett dette før — prøv å huske svaret">
              🔁 Repetisjon
            </span>
          )}
        </span>
        <span class="quiz-q__meta">
          {q.category && <span class="quiz-q__category">{q.category}</span>}
          {canPin && (
            <SaveButton
              type="quiz" date={date} index={i} compact
              id={buildId('quiz', { question: q.question })}
              saved={saved.has(buildId('quiz', { question: q.question }))}
            />
          )}
        </span>
      </header>
      <p class="quiz-q__question">{q.question}</p>
      <div class="quiz-q__options" role="group" aria-label="Svaralternativer">
        {q.options.map((opt) => (
          <button type="button" class="quiz-opt" data-opt={opt}>{opt}</button>
        ))}
      </div>
      <p class="quiz-q__verdict" hidden></p>
    </article>
  ))}
</div>
<p class="quiz-score" hidden>
  <span class="quiz-score__text"></span>
</p>

<script is:inline>
  (() => {
    const cards = Array.from(document.querySelectorAll('.quiz-q'));
    const scoreEl = document.querySelector('.quiz-score');
    const scoreText = document.querySelector('.quiz-score__text');
    let answered = 0;
    let correct = 0;

    for (const card of cards) {
      const answer = card.dataset.answer;
      const verdict = card.querySelector('.quiz-q__verdict');
      card.querySelectorAll('.quiz-opt').forEach((btn) => {
        btn.addEventListener('click', () => {
          if (card.classList.contains('quiz-q--done')) return;
          card.classList.add('quiz-q--done');
          const right = btn.dataset.opt === answer;
          card.querySelectorAll('.quiz-opt').forEach((b) => {
            b.disabled = true;
            if (b.dataset.opt === answer) b.classList.add('quiz-opt--correct');
          });
          if (right) {
            correct += 1;
            verdict.textContent = '✓ Riktig!';
            verdict.classList.add('quiz-q__verdict--right');
          } else {
            btn.classList.add('quiz-opt--wrong');
            verdict.textContent = `✗ Feil — riktig svar: ${answer}`;
            verdict.classList.add('quiz-q__verdict--wrong');
          }
          verdict.hidden = false;
          answered += 1;
          if (answered === cards.length && scoreEl && scoreText) {
            scoreText.textContent = `Dagens fasit: ${correct} av ${cards.length} riktige 🧠`;
            scoreEl.hidden = false;
          }
        });
      });
    }
  })();
</script>
