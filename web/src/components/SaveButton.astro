---
// Pin-knapp for én studie. Ren markup — all logikk ligger i SaveRuntime.astro, som
// fanger klikk via delegering (én lytter for hele siden).
//
// `saved` kommer fra serveren, så stjernen er fylt allerede i første paint. Uten det
// ville hvert kort blinket fra tom til fylt etter hydrering.
const { date, url, id = null, saved = false } = Astro.props;
---

<button
  class:list={['pin', saved && 'pin--on']}
  type="button"
  data-pin
  data-date={date}
  data-id={saved && id ? id : undefined}
  data-url={url}
  aria-pressed={saved ? 'true' : 'false'}
  title={saved ? 'Fjern fra lagrede' : 'Lagre denne studien'}
>
  <span class="pin__star" aria-hidden="true">{saved ? '★' : '☆'}</span>
  <span class="pin__text">{saved ? 'Lagret' : 'Lagre'}</span>
</button>
