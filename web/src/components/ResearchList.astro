---
// Full forskningsvisning for én dag — brukes av forskning.modr.no-sidene.
// Studiene grupperes etter kategori (Medisin/Trening/Kosthold); studier uten
// kategori-etikett (gamle briefinger) samles under «Øvrig». Anker-id `s<i>`
// (i = studiens posisjon i research_md) matcher lenkene fra nyhetssiden.
import { splitResearch, RESEARCH_CATEGORIES } from '../lib/briefings.js';
import { savedIdSet, buildId } from '../lib/saved.js';
import { writingEnabled, isAuthed } from '../lib/auth.js';
import SaveButton from './SaveButton.astro';
import SaveRuntime from './SaveRuntime.astro';

const { b } = Astro.props;

// Lagrede ID-er hentes server-side, så pin-stjernen er fylt allerede i første paint.
// Uten kodeord konfigurert på serveren skjules pinning helt (feiler synlig, ikke åpent).
const canPin = writingEnabled();
const saved = canPin ? await savedIdSet() : new Set();
const authed = canPin && isAuthed(Astro.cookies);

const studies = splitResearch(b.research_md).map((st, i) => ({
  ...st,
  anchor: `s${i}`,
  savedId: st.url ? buildId('study', { url: st.url }) : null,
}));

const groups = RESEARCH_CATEGORIES.map((cat) => ({
  ...cat,
  studies: studies.filter((st) => st.category === cat.id),
}));
const rest = studies.filter((st) => !RESEARCH_CATEGORIES.some((c) => c.id === st.category));
if (rest.length) groups.push({ id: 'annet', label: 'Øvrig', emoji: '🔬', studies: rest });

// Etikettene fra generatorens SYSTEM_PROMPT. «Hva som ble gjort» og «Relevans» er det gamle
// formatet — beholdes så arkiverte briefinger fortsatt rendrer med ikon.
const PART_ICON = {
  Metode: '🔬',
  'Hva som ble gjort': '🔬',
  Resultat: '📊',
  'Hva det betyr for deg': '💡',
  Relevans: '💡',
  Forbehold: '⚠️',
};

// Konklusjonen — det leseren skal ta med seg — fremheves; forbeholdene dempes.
const KEY_PARTS = ['Hva det betyr for deg', 'Relevans'];

const partClass = (label) => {
  if (KEY_PARTS.includes(label)) return 'study__part study__part--key';
  if (label === 'Forbehold') return 'study__part study__part--caveat';
  return 'study__part';
};
---

{
  studies.length ? (
    groups.filter((g) => g.studies.length).map((g) => (
      <section>
        <h2 class="section-label">{`${g.emoji} ${g.label} · ${g.studies.length}`}</h2>
        <div class="research-grid research-grid--wide">
          {g.studies.map((st) => (
            <article class="card study" id={st.anchor}>
              <h3 class="study__title">
                {st.url ? <a href={st.url} target="_blank" rel="noopener">{st.title}</a> : st.title}
              </h3>
              {canPin && st.url && (
                <div class="study__actions">
                  <SaveButton date={b.date} url={st.url} id={st.savedId} saved={saved.has(st.savedId)} />
                </div>
              )}
              {st.parts.length ? (
                <div class="study__parts">
                  {st.parts.map((p) => (
                    <div class={partClass(p.label)}>
                      <div class="study__label">
                        <span class="study__label-icon" aria-hidden="true">{PART_ICON[p.label] || '•'}</span>
                        {p.label}
                      </div>
                      <div class="study__text" set:html={p.html} />
                    </div>
                  ))}
                </div>
              ) : (
                <div class="prose" set:html={st.html} />
              )}
            </article>
          ))}
        </div>
      </section>
    ))
  ) : (
    <p class="muted">Ingen forskningsbriefing denne dagen.</p>
  )
}

{canPin && <SaveRuntime authed={authed} />}
