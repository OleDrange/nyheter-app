---
// Full forskningsvisning for én dag — brukes av forskning.modr.no-sidene.
// Studiene grupperes etter kategori (Medisin/Trening/Kosthold); studier uten
// kategori-etikett (gamle briefinger) samles under «Øvrig». Anker-id `s<i>`
// (i = studiens posisjon i research_md) matcher lenkene fra nyhetssiden.
import { splitResearch, RESEARCH_CATEGORIES } from '../lib/briefings.js';

const { b } = Astro.props;
const studies = splitResearch(b.research_md).map((st, i) => ({ ...st, anchor: `s${i}` }));

const groups = RESEARCH_CATEGORIES.map((cat) => ({
  ...cat,
  studies: studies.filter((st) => st.category === cat.id),
}));
const rest = studies.filter((st) => !RESEARCH_CATEGORIES.some((c) => c.id === st.category));
if (rest.length) groups.push({ id: 'annet', label: 'Øvrig', emoji: '🔬', studies: rest });

const PART_ICON = {
  'Hva som ble gjort': '🔬',
  Resultat: '📊',
  Relevans: '💡',
};
---

{
  studies.length ? (
    groups.filter((g) => g.studies.length).map((g) => (
      <section>
        <h2 class="section-label">{`${g.emoji} ${g.label} · ${g.studies.length}`}</h2>
        <div class="research-grid research-grid--wide">
          {g.studies.map((st) => (
            <article class="card study" id={st.anchor}>
              <h3 class="study__title">
                {st.url ? <a href={st.url} target="_blank" rel="noopener">{st.title}</a> : st.title}
              </h3>
              {st.parts.length ? (
                <div class="study__parts">
                  {st.parts.map((p) => (
                    <div class={p.label === 'Relevans' ? 'study__part study__part--key' : 'study__part'}>
                      <div class="study__label">
                        <span class="study__label-icon" aria-hidden="true">{PART_ICON[p.label] || '•'}</span>
                        {p.label}
                      </div>
                      <div class="study__text" set:html={p.html} />
                    </div>
                  ))}
                </div>
              ) : (
                <div class="prose" set:html={st.html} />
              )}
            </article>
          ))}
        </div>
      </section>
    ))
  ) : (
    <p class="muted">Ingen forskningsbriefing denne dagen.</p>
  )
}
