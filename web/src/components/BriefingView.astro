---
// Felles visning for én briefing — brukes av både forsiden og enkeltdag-siden.
import WeatherCard from './WeatherCard.astro';
import MarketStrip from './MarketStrip.astro';
import { splitNewsSections, splitResearch, getMarketHistory } from '../lib/briefings.js';

const { b } = Astro.props;
const sections = splitNewsSections(b.news_md);
const studies = splitResearch(b.research_md);
const marketHistory = b.market ? await getMarketHistory({ endDate: b.date }) : {};

// Ikon per merket del i forskningsabstractene (structured-abstract-stil).
const PART_ICON = {
  'Hva som ble gjort': '🔬',
  Resultat: '📊',
  Relevans: '💡',
};
---

{(b.weather || b.market) && (
  <div class="top-grid">
    {b.weather && <WeatherCard weather={b.weather} />}
    {b.market && <MarketStrip market={b.market} history={marketHistory} />}
  </div>
)}

<section>
  <h2 class="section-label">Nyhetsbriefing</h2>
  {
    sections.length ? (
      <div class="cards-grid">
        {sections.map((s) => (
          <article class="card section-card">
            <header class="section-card__head">
              {s.emoji && <span class="section-card__emoji" aria-hidden="true">{s.emoji}</span>}
              <h3 class="section-card__title">{s.title}</h3>
            </header>
            <div class="prose" set:html={s.html} />
          </article>
        ))}
      </div>
    ) : (
      <p class="muted">Ingen nyhetsbriefing denne dagen.</p>
    )
  }
</section>

<section>
  <h2 class="section-label">Forskningsbriefing</h2>
  {
    studies.length ? (
      <div class="research-grid">
        {studies.map((st) => (
          <article class="card study">
            <h3 class="study__title">
              {st.url ? <a href={st.url} target="_blank" rel="noopener">{st.title}</a> : st.title}
            </h3>
            {st.parts.length ? (
              <div class="study__parts">
                {st.parts.map((p) => (
                  <div class={p.label === 'Relevans' ? 'study__part study__part--key' : 'study__part'}>
                    <div class="study__label">
                      <span class="study__label-icon" aria-hidden="true">{PART_ICON[p.label] || '•'}</span>
                      {p.label}
                    </div>
                    <div class="study__text" set:html={p.html} />
                  </div>
                ))}
              </div>
            ) : (
              <div class="prose" set:html={st.html} />
            )}
          </article>
        ))}
      </div>
    ) : (
      <p class="muted">Ingen forskningsbriefing denne dagen.</p>
    )
  }
</section>
