---
// Felles visning for én briefing — brukes av både forsiden og enkeltdag-siden.
import WeatherCard from './WeatherCard.astro';
import MarketStrip from './MarketStrip.astro';
import QuizCard from './QuizCard.astro';
import RiddleCard from './RiddleCard.astro';
import LearningCard from './LearningCard.astro';
import BrannCard from './BrannCard.astro';
import {
  splitNewsSections,
  splitResearch,
  getMarketHistory,
  FORSKNING_URL,
  RESEARCH_CATEGORIES,
} from '../lib/briefings.js';

const { b } = Astro.props;
const sections = splitNewsSections(b.news_md);
const studies = splitResearch(b.research_md);
const marketHistory = b.market ? await getMarketHistory({ endDate: b.date }) : {};

const catLabel = (id) => RESEARCH_CATEGORIES.find((c) => c.id === id)?.label;
---

{(b.weather || b.market) && (
  <div class="top-grid">
    {b.weather && <WeatherCard weather={b.weather} />}
    {b.market && <MarketStrip market={b.market} history={marketHistory} />}
  </div>
)}

{b.riddles?.length > 0 && (
  <section>
    <h2 class="section-label">Dagens gåter</h2>
    <RiddleCard riddles={b.riddles} />
  </section>
)}

{b.quiz?.length > 0 && (
  <section>
    <h2 class="section-label">Dagens quiz</h2>
    <QuizCard quiz={b.quiz} />
  </section>
)}

{(b.learning?.podcasts?.length > 0 || b.learning?.books?.length > 0) && (
  <section>
    <h2 class="section-label">Dagens inspirasjon</h2>
    <LearningCard learning={b.learning} />
  </section>
)}

<section>
  <h2 class="section-label">Nyhetsbriefing</h2>
  {
    sections.length ? (
      <div class="cards-grid">
        {sections.map((s) => (
          <article class="card section-card">
            <header class="section-card__head">
              {s.emoji && <span class="section-card__emoji" aria-hidden="true">{s.emoji}</span>}
              <h3 class="section-card__title">{s.title}</h3>
            </header>
            <div class="prose" set:html={s.html} />
            {b.brann && /bergen/i.test(s.title) && <BrannCard brann={b.brann} />}
          </article>
        ))}
      </div>
    ) : (
      <p class="muted">Ingen nyhetsbriefing denne dagen.</p>
    )
  }
</section>

<section>
  <h2 class="section-label">Forskning</h2>
  {
    studies.length ? (
      <div class="card research-links-card">
        <ul class="research-links">
          {studies.map((st, i) => (
            <li>
              <a href={`${FORSKNING_URL}/b/${b.date}#s${i}`}>{st.title}</a>
              {catLabel(st.category) && <span class="research-links__cat">{catLabel(st.category)}</span>}
            </li>
          ))}
        </ul>
        <a class="research-links__more" href={`${FORSKNING_URL}/b/${b.date}`}>
          Les oppsummeringene på forskning.modr.no →
        </a>
      </div>
    ) : (
      <p class="muted">Ingen forskningsbriefing denne dagen.</p>
    )
  }
</section>
