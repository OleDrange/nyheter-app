---
// Kompakt dagsgraf for én ticker: linje + områdefyll over opptil ~8 punkter
// (ett per handelsdag), verdi-etikett på første/siste punkt + min/maks (når de
// ikke ER første/siste), dag-i-måneden under hvert punkt. Inline SVG, ingen
// klient-JS — hover-verdier via native <title> på usynlige kolonne-flater.
// Fargelegges av trenden (første → siste; grå når flat). Siste punkt fremhevet
// med større dot og surface-ring.
const { points = [], width = 280, height = 92 } = Astro.props;

const pts = points.filter((p) => typeof p.value === 'number' && Number.isFinite(p.value));
const has = pts.length >= 1;

const padX = 10;
const plotTop = 20;
const plotBottom = 60;
const plotH = plotBottom - plotTop;

let coords = [];
let line = '';
let area = '';
let trend = 'flat';

if (has) {
  const vals = pts.map((p) => p.value);
  const min = Math.min(...vals);
  const max = Math.max(...vals);
  const span = max - min || 1;
  const n = pts.length;
  const stepX = n > 1 ? (width - padX * 2) / (n - 1) : 0;
  const maxIdx = vals.indexOf(max);
  const minIdx = vals.indexOf(min);
  coords = pts.map((p, i) => {
    const x = n > 1 ? padX + i * stepX : width / 2;
    const y = plotBottom - ((p.value - min) / span) * plotH;
    const endpoint = i === 0 || i === n - 1;
    return {
      x,
      y,
      label: p.label,
      day: p.day,
      first: i === 0,
      last: i === n - 1,
      // Min/maks merkes kun når de ikke er endepunkter (som alt har etikett).
      isMax: i === maxIdx && !endpoint && span > 0,
      isMin: i === minIdx && !endpoint && span > 0,
    };
  });
  // Usynlig hover-kolonne per punkt (native <title>-tooltip, ingen JS).
  coords.forEach((c, i) => {
    c.hx0 = i === 0 ? 0 : (coords[i - 1].x + c.x) / 2;
    c.hx1 = i === n - 1 ? width : (c.x + coords[i + 1].x) / 2;
  });
  line = coords.map((c, i) => `${i ? 'L' : 'M'}${c.x.toFixed(1)},${c.y.toFixed(1)}`).join(' ');
  if (n > 1) {
    area = `${line} L${coords[n - 1].x.toFixed(1)},${plotBottom} L${coords[0].x.toFixed(1)},${plotBottom} Z`;
    trend = vals[n - 1] > vals[0] ? 'up' : vals[n - 1] < vals[0] ? 'down' : 'flat';
  }
}

// Maks-etikett alltid over sitt punkt, min-etikett alltid under — marginene
// over/under båndet er ledige nettopp ved ekstremene. Endepunkt-etiketter
// flippes inn i plottet (over når punktet er lavt, under når det er høyt),
// så de aldri kolliderer med min/maks-etikettene i marginene.
const labelY = (c) => {
  if (c.isMax) return c.y - 8;
  if (c.isMin) return c.y + 15;
  return c.y < (plotTop + plotBottom) / 2 ? c.y + 16 : c.y - 8;
};
---

{
  has ? (
    <svg
      class={`mtrend mtrend--${trend}`}
      viewBox={`0 0 ${width} ${height}`}
      preserveAspectRatio="xMidYMid meet"
      role="img"
    >
      {area && <path class="mtrend__area" d={area} />}
      {coords.length > 1 && <path class="mtrend__line" d={line} fill="none" />}
      {coords.map((c) => (
        <g>
          <rect class="mtrend__hit" x={c.hx0} y="0" width={c.hx1 - c.hx0} height={height}>
            <title>{`${c.day}.: ${c.label}`}</title>
          </rect>
          {(c.first || c.last || c.isMax || c.isMin) && (
            <text
              class={c.last ? 'mtrend__val mtrend__val--last' : 'mtrend__val'}
              x={c.x}
              y={labelY(c)}
              text-anchor={
                coords.length === 1 ? 'middle' : c.last ? 'end' : c.first ? 'start' : 'middle'
              }
            >
              {c.label}
            </text>
          )}
          <circle
            class={c.last ? 'mtrend__dot mtrend__dot--last' : 'mtrend__dot'}
            cx={c.x}
            cy={c.y}
            r={c.last ? 4 : c.isMax || c.isMin ? 3 : 2}
          />
          <text class="mtrend__day" x={c.x} y={height - 4} text-anchor="middle">
            {c.day}
          </text>
        </g>
      ))}
    </svg>
  ) : (
    <div class="mtrend mtrend--empty muted">Ny — bygger historikk</div>
  )
}
