# Kopier denne filen til .env og fyll inn dine API-nøkler.
# .env skal ALDRI committes til git.

ANTHROPIC_API_KEY=sk-ant-...

# Valgfri — kun nødvendig for Notion-publisering
NOTION_API_KEY=ntn_...
NOTION_PARENT_PAGE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Valgfri — feilvarsling for den daglige generatoren (se healthcheck.py / notify.py)
# ALERT_WEBHOOK_URL: Slack/Discord-webhook som får melding hvis briefingen mangler/feiler.
# HEARTBEAT_URL: pinges ved suksess — pek mot healthchecks.io e.l. som varsler hvis
#                pinget uteblir (fanger at cron aldri kjørte).
ALERT_WEBHOOK_URL=
HEARTBEAT_URL=
